{
  "expo": {
    "name": "GTG Tracker",
    "slug": "gtg-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "description": "GTG Tracker — Grease The Groove pelo método Pavel Tsatsouline. Força e resistência com disciplina.",
    "scheme": "gtg-tracker",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gtgtracker.mobile",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.gtgtracker.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-system-ui"
    ],
    "extra": {
      "eas": {
        "projectId": "5ae7bb67-7ce1-41c8-b074-1499e99d9d69"
      }
    },
    "owner": "bamaralf"
  }
}
