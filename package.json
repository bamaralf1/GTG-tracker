{
  "name": "gtg-tracker-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test:shared": "cd shared && npm test",
    "build:mobile:web": "cd mobile && npx expo export --platform web",
    "build:mobile:android": "cd mobile && npx expo export --platform android",
    "start:mobile": "cd mobile && npx expo start",
    "start:desktop": "cd desktop && electron .",
    "build:desktop": "cd desktop && npm run dist:win",
    "build:desktop:dir": "cd desktop && npm run pack",
    "icons:desktop": "cd desktop && npm run icons",
    "test:all": "npm run test:shared"
  }
}
